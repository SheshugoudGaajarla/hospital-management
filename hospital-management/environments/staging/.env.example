APP_ENV=staging
API_PORT=8000
WEB_PORT=3000
DATABASE_URL=<staging-db-url>
REDIS_URL=<staging-redis-url>
JWT_SECRET=<staging-secret>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=https://staging.your-hospital-domain.com
LOG_LEVEL=INFO
REQUEST_LOG_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=20
RATE_LIMIT_WRITE_PER_MINUTE=120
RATE_LIMIT_BOOTSTRAP_PER_HOUR=3
POSTGRES_USER=<staging-postgres-user>
POSTGRES_PASSWORD=<staging-postgres-password>
POSTGRES_DB=<staging-postgres-db>
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14
BACKUP_DIR=/backups/postgres
