APP_ENV=prod
API_PORT=8000
WEB_PORT=3000
DATABASE_URL=<prod-db-url>
REDIS_URL=<prod-redis-url>
JWT_SECRET=<prod-secret>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=https://your-hospital-domain.com
LOG_LEVEL=INFO
REQUEST_LOG_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MINUTE=15
RATE_LIMIT_WRITE_PER_MINUTE=100
RATE_LIMIT_BOOTSTRAP_PER_HOUR=2
POSTGRES_USER=<prod-postgres-user>
POSTGRES_PASSWORD=<prod-postgres-password>
POSTGRES_DB=<prod-postgres-db>
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=/backups/postgres
